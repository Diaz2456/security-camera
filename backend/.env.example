# Server
PORT=3000
NODE_ENV=production

# MongoDB Atlas connection string (M0 free tier, 512MB)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/security-cam?retryWrites=true&w=majority

# Camera API key (shared secret for ESP32 authentication)
CAMERA_API_KEY=change-me-to-a-long-random-string

# JWT secret for admin auth
JWT_SECRET=change-me-to-another-long-random-string

# Admin credentials (only used for initial seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CommandeR48

# Storage limits (in bytes, 500MB cap)
MAX_STORAGE_BYTES=524288000
ALERT_THRESHOLD_BYTES=419430400   # 80%
ROLLING_DELETE_TARGET_BYTES=419430400
ROLLING_DELETE_EMERGENCY_TARGET_BYTES=419430400

# Retention (seconds)
DEFAULT_RETENTION_SECONDS=604800   # 7 days
CONFIG_COLLECTION_NAME=config
